# Copy to `.env` in this folder (same directory as docker-compose.yml).
# docker compose automatically loads `.env`.

# Required for production: long random string (e.g. openssl rand -hex 32).
# A weak default exists in docker-compose only for a first boot — override here.
SECRET_KEY=

# Strongly recommended for production: Fernet key for SMTP passwords at rest
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Postgres (defaults shown — override in production)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=email_marketing

# Nginx: host port published on the cloud VM (open this port in firewall / security group).
# Use 80 only if nothing else binds to it (may require root on some hosts).
HTTP_PORT=8080

# Bind address on the host (default all interfaces — required for cloud public IP).
# Use 127.0.0.1 to listen only on localhost (e.g. with another reverse proxy on the same machine).
HTTP_BIND=0.0.0.0

# Optional: pin image names when tagging/pushing to a registry.
# BACKEND_IMAGE=myregistry/emp-backend:v1
# FRONTEND_IMAGE=myregistry/emp-web:v1
# PROXY_IMAGE=myregistry/emp-nginx:v1

# Leave empty when using nginx (browser calls /api/v1 on same host).
# Set only if UI is built for a separate API origin (e.g. https://api.example.com).
NEXT_PUBLIC_API_URL=

# If `docker compose build` fails on the web image with npm ETIMEDOUT to registry.npmjs.org,
# point npm at a mirror (examples — pick one that works from your cloud region):
# NPM_REGISTRY=https://registry.npmmirror.com
# NPM_REGISTRY=https://registry.npmjs.org/
NPM_REGISTRY=
