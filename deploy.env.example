# Copy to `.env` in this folder (same directory as docker-compose.yml).
# docker compose automatically loads `.env`.

# Required for production: long random string (e.g. openssl rand -hex 32).
# A weak default exists in docker-compose only for a first boot — override here.
SECRET_KEY=

# Strongly recommended for production: Fernet key for SMTP passwords at rest
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Postgres (defaults shown — override in production)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=email_marketing

# Published HTTP port (nginx). Default 8080 avoids needing root for port 80.
HTTP_PORT=8080

# Leave empty when using nginx (browser calls /api/v1 on same host).
# Set only if UI is built for a separate API origin (e.g. https://api.example.com).
NEXT_PUBLIC_API_URL=
